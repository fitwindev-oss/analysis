# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ─────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE / editors ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Runtime / recording / result data ────────────────────────────────
# Everything under data/ is operator-machine-specific output:
#   - sessions/        Raw recordings (videos, force csv, pose npz)
#                      — large (26 GB+) and contain PII
#   - benchmarks/      Sample/regression PDF + HTML reports
#   - calibration/     Camera intrinsics/extrinsics, world-frame,
#                      encoder/DAQ scale calibrations — all measured
#                      from THIS particular hardware setup; a clone
#                      to a new machine should re-run the calibration
#                      scripts (scripts/calibrate_*.py) instead of
#                      reusing values from another rig
#   - biomech.db       Subject database — PII
#
# None of these should live in version control. The schemas and the
# tools that produce them are tracked (src/, scripts/, docs/), so a
# fresh clone can regenerate everything.
data/

# Allow specific schema/template files if explicitly added:
#   git add -f data/_schema/...
# (force-add overrides this gitignore entry).

# Config backup auto-generated by calibrate_daq_scale.py --apply
config.py.bak

# ── Generated artifacts ──────────────────────────────────────────────
# Generated PDFs/xlsx should not be committed (rebuild from result.json)
data/sessions/**/*.pdf
data/sessions/**/*.xlsx

# Temporary test/debug artifacts
_phase_*.py
_scratch_*.py
_tmp_*/
_tmp_patent/
*.tmp

# Disposable test helpers (e.g. tools/_test_*.py — one-off scripts
# that create fixture rows for manual verification, not part of the
# automated test suite under tests/).
_test_*.py
**/_test_*.py

# Accidentally-created empty files from mistyped commands (pip / python
# / version numbers as filenames). Re-listed explicitly so the initial
# commit isn't polluted by "26.0.1" / "pip" / "python" zero-byte files.
/26.0.1
/pip
/python

# ── Model caches (auto-downloaded) ───────────────────────────────────
# MediaPipe task files downloaded by the app at first run
resources/mediapipe/*.task

# ── Logs ─────────────────────────────────────────────────────────────
*.log
logs/
