      }
    },
    "right": {
      "mean_velocity_mm_s": {
        "default": {"ok_range":[20, 60], "caution_range":[10, 100], "lower_is_better": true}
      },
      "ellipse95_area_mm2": {
        "default": {"ok_range":[200, 1500], "caution_range":[100, 3000], "lower_is_better": true}
      }
    }
  },

  "balance_ec": {
    "two": {
      "mean_velocity_mm_s": {
        "adult_18_40_any":{"ok_range":[12, 35], "caution_range":[8, 60],   "lower_is_better": true},
        "senior_60p_any": {"ok_range":[25, 65], "caution_range":[15, 130], "lower_is_better": true},
