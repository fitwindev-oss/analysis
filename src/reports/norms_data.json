{
  "_meta": {
    "version": 1,
    "last_updated": "2026-04-22",
    "sources": {
      "balance_eo":   "Prieto 1996; Maki 2000; WHO SBT norms",
      "balance_ec":   "Prieto 1996; Romberg ratio Pagnacco 2015",
      "cmj":          "Claudino 2017 systematic review; Taylor 2010",
      "romberg":      "Prieto 1996 — EC/EO ratio; clinical >1.5 alert"
    },
    "age_buckets": [
      {"key": "adult_18_40",  "desc": "성인 18~40세"},
      {"key": "adult_40_60",  "desc": "중년 40~60세"},
      {"key": "senior_60p",   "desc": "고령 60세 이상"}
    ],
    "schema": {
      "ok_range":       "[low, high] — the 'good / typical' band",
      "caution_outside":"outside [ok_range] but within caution_range = amber",
      "caution_range":  "[low, high] — wider band before red",
      "lower_is_better":"if true, values below ok_range.low are still OK; above are worse",
      "higher_is_better":"if true, values above ok_range.high are still OK; below are worse"
    }
  },

  "balance_eo": {
    "two": {
      "mean_velocity_mm_s": {
        "adult_18_40_M": {"ok_range":[8, 20],  "caution_range":[5, 35],  "lower_is_better": true},
        "adult_18_40_F": {"ok_range":[8, 22],  "caution_range":[5, 38],  "lower_is_better": true},
        "adult_40_60_any":{"ok_range":[10, 25],"caution_range":[7, 45],  "lower_is_better": true},
        "senior_60p_any": {"ok_range":[15, 35],"caution_range":[10, 70], "lower_is_better": true},
        "default":        {"ok_range":[8, 25], "caution_range":[5, 45],  "lower_is_better": true}
      },
      "ellipse95_area_mm2": {
        "adult_18_40_any":{"ok_range":[50, 400],  "caution_range":[30, 900],  "lower_is_better": true},
        "senior_60p_any": {"ok_range":[80, 700],  "caution_range":[50, 1500], "lower_is_better": true},
        "default":        {"ok_range":[50, 500],  "caution_range":[30, 1000], "lower_is_better": true}
      },
      "path_length_mm": {
        "default":        {"ok_range":[100, 700], "caution_range":[50, 1200], "lower_is_better": true}
      },
      "rms_ml_mm": {
        "default":        {"ok_range":[1, 4],   "caution_range":[0.5, 7],   "lower_is_better": true}
